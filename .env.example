# Environment Variables
#
# Copy this file to .env and fill in your values.
# Vite exposes variables prefixed with VITE_ to client code.

# Your deployed Google Apps Script URL (combined.gs)
VITE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# App branding
VITE_APP_NAME=S
VITE_BASE_DISPLAY=../
VITE_TAGLINE=Serverless, safe, secure, and fast.
