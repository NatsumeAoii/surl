{
    "name": "surl",
    "private": true,
    "version": "1.0.2-b",
    "description": "Serverless URL shortener with a React/Vite frontend and Google Apps Script backend.",
    "homepage": "https://natsumeaoii.github.io/surl/",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/natsumeaoii/surl.git"
    },
    "bugs": {
        "url": "https://github.com/natsumeaoii/surl/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "lint": "eslint src --report-unused-disable-directives",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "validate:deploy": "node scripts/validate-deploy-artifact.mjs",
        "verify:pages": "node scripts/verify-deployed-pages.mjs"
    },
    "dependencies": {
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.39.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.0",
        "globals": "^17.3.0",
        "prettier": "^3.8.1",
        "typescript": "~5.7.0",
        "vite": "^8.0.12",
        "vitest": "^4.1.5"
    }
}
